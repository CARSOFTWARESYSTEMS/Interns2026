# ==================================================
# EV.ENGINEER™ Aerospace Intelligence & Cybersecurity
# ==================================================

# --------------------------------------------------
# Application
# --------------------------------------------------

VITE_APP_NAME=Aerospace Intelligence & Cybersecurity
VITE_APP_ENV=development

# --------------------------------------------------
# Data Mode
# local | gdrive | firebase
# --------------------------------------------------

VITE_DATA_MODE=local

# --------------------------------------------------
# Firebase
# --------------------------------------------------

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --------------------------------------------------
# Google Drive (required when VITE_DATA_MODE=gdrive)
# Create OAuth 2.0 Client ID at console.cloud.google.com
# Authorised JavaScript origins: http://localhost:5173
# Scope required: https://www.googleapis.com/auth/drive.file
# --------------------------------------------------

VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# --------------------------------------------------
# GitHub (Future)
# --------------------------------------------------

VITE_GITHUB_ORG=EV-ENGINEER

# --------------------------------------------------
# Feature Flags
# --------------------------------------------------

VITE_ENABLE_FIREBASE=true
VITE_ENABLE_GOOGLE_DRIVE=false
VITE_ENABLE_GITHUB=false
