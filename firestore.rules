rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Super admins are always Platform Admin regardless of stored role.
    function isSuperAdminEmail() {
      return isSignedIn() && request.auth.token.email in [
        'carsoftwaresystems@gmail.com',
        'sudarshana.karkala@gmail.com'
      ];
    }

    // Reads the caller's role from their user document (costs 1 extra read).
    // Returns empty string if the document doesn't exist yet (first login).
    function callerRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    function isPlatformAdmin() { return isSuperAdminEmail() || callerRole() == 'Platform Admin'; }
    function isManager()       { return callerRole() == 'Engineering Manager'; }
    function isArchitect()     { return callerRole() == 'Architect'; }
    function isQA()            { return callerRole() == 'QA Engineer'; }
    function isDeveloper()     { return callerRole() == 'Developer'; }
    function isHRManager()     { return callerRole() == 'HR Manager'; }

    function canManageUsers() { return isPlatformAdmin() || isManager(); }
    function canReadAll()     { return isPlatformAdmin() || isManager() || isArchitect(); }

    // People Operations — Platform Admin (full), Engineering Manager (team),
    // HR Manager (people ops) can manage recruitment/onboarding/policies.
    // Everyone signed in can read/write their own profile-linked records
    // (self profile, self leave, self reviews) via the isOwnPeopleRecord check.
    function canManagePeopleOps() { return isPlatformAdmin() || isManager() || isHRManager(); }
    function isOwnPeopleRecord()  { return isSignedIn() && resource.data.get('uid', '') == request.auth.uid; }

    // ── Users ──────────────────────────────────────────────────────────────
    // Each user document is keyed by uid.
    match /users/{uid} {
      // Any authenticated user can read their own profile.
      // Admin / Manager can read all profiles (needed for user management pages).
      allow read: if isOwner(uid) || canReadAll();

      // Create own profile on first login — no role check needed (doc doesn't exist yet).
      allow create: if isOwner(uid);

      // Update own profile, or admin can update any profile (role assignment).
      allow update: if isOwner(uid) || isPlatformAdmin();

      // Only Platform Admin can delete.
      allow delete: if isPlatformAdmin();
    }

    // ── Skills ─────────────────────────────────────────────────────────────
    match /userSkills/{uid} {
      allow read:  if isOwner(uid) || canReadAll();
      allow write: if isOwner(uid) || isPlatformAdmin() || isManager();
    }

    // ── Resumes ────────────────────────────────────────────────────────────
    match /userResumes/{uid} {
      allow read:  if isOwner(uid) || canReadAll();
      allow write: if isOwner(uid);
    }

    // ── Audit Logs ─────────────────────────────────────────────────────────
    // Any signed-in user can write logs (system writes on their behalf).
    // Users can only read their own logs; admins can read all.
    match /auditLogs/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn() && (resource.data.uid == request.auth.uid || isPlatformAdmin());
      allow update, delete: if false; // Logs are immutable.
    }

    // ── Login History ──────────────────────────────────────────────────────
    match /loginHistory/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn() && (resource.data.uid == request.auth.uid || isPlatformAdmin());
      allow update, delete: if false;
    }

    // ── Invitations ────────────────────────────────────────────────────────
    match /invitations/{docId} {
      allow read:   if isSignedIn();
      allow create: if canManageUsers();
      allow update: if canManageUsers();
      allow delete: if isPlatformAdmin();
    }

    // ── Organizations ──────────────────────────────────────────────────────
    match /organizations/{docId} {
      allow read:  if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    match /organizationMembers/{docId} {
      allow read:  if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    // ── Engineering Data (Firebase adapter: VITE_DATA_MODE=firebase) ───────
    // Collection path: ev_data/{collection}/items/{docId}
    match /ev_data/{col}/items/{docId} {
      allow read:  if isSignedIn();
      allow write: if isPlatformAdmin() || isManager() || isArchitect();
    }

    // ── M05 Assignments ────────────────────────────────────────────────────
    // Developers read/update only their own; managers/admins/architects read all.
    match /assignments/{docId} {
      allow read: if isSignedIn() && (
        resource.data.developerId == request.auth.uid || canReadAll()
      );
      allow create: if canManageUsers();
      allow update: if canManageUsers() ||
        (isSignedIn() && resource.data.developerId == request.auth.uid);
      allow delete: if isPlatformAdmin();
    }

    // ── Assignment History (immutable audit trail) ─────────────────────────
    match /assignmentHistory/{docId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.performedBy == request.auth.uid || canReadAll()
      );
      allow update, delete: if false;
    }

    // ── Daily Engineering Check-ins ────────────────────────────────────────
    // Doc ID format: {developerId}_{YYYY-MM-DD}
    match /dailyEngineeringCheckins/{docId} {
      allow read: if isSignedIn() && (
        resource.data.developerId == request.auth.uid || canReadAll()
      );
      // Developer writes their own; use request.resource for create (resource doesn't exist yet).
      allow create: if isSignedIn() && (
        request.resource.data.developerId == request.auth.uid || canManageUsers()
      );
      allow update: if isSignedIn() && (
        resource.data.developerId == request.auth.uid || canManageUsers()
      );
      allow delete: if isPlatformAdmin();
    }

    // ── Weekly Engineering Reports ─────────────────────────────────────────
    match /weeklyEngineeringReports/{docId} {
      allow read: if isSignedIn() && (
        resource.data.developerId == request.auth.uid || canReadAll()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.developerId == request.auth.uid || canManageUsers()
      );
      allow delete: if isPlatformAdmin();
    }

    // ── Developer Capacity ─────────────────────────────────────────────────
    // Non-sensitive — any authenticated user can read (managers need to see all).
    match /developerCapacity/{devId} {
      allow read:  if isSignedIn();
      allow write: if canManageUsers();
    }

    // ── Notifications ──────────────────────────────────────────────────────
    // Recipients read/update their own; any signed-in user can create
    // (developers create notifications for managers on accept/decline).
    match /notifications/{docId} {
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || canReadAll()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || canManageUsers()
      );
      allow delete: if isPlatformAdmin();
    }

    // ── People Operations ──────────────────────────────────────────────────
    // Foundation collections for interns/employees/contractors: recruitment,
    // onboarding, lifecycle profiles, 1:1 reviews, leave, policies, culture.

    match /peopleProfiles/{docId} {
      allow read:   if isSignedIn() && (isOwnPeopleRecord() || canManagePeopleOps() || canReadAll());
      allow create: if canManagePeopleOps();
      allow update: if canManagePeopleOps() || isOwnPeopleRecord();
      allow delete: if isPlatformAdmin();
    }

    match /peopleJobOpenings/{docId} {
      allow read:   if isSignedIn();
      allow write:  if canManagePeopleOps();
    }

    match /peopleCandidates/{docId} {
      allow read:   if canManagePeopleOps() || canReadAll();
      allow write:  if canManagePeopleOps();
    }

    match /peopleApplications/{docId} {
      allow read:   if canManagePeopleOps() || canReadAll();
      allow write:  if canManagePeopleOps();
    }

    match /peopleInterviews/{docId} {
      allow read:   if canManagePeopleOps() || canReadAll() ||
        (isSignedIn() && resource.data.interviewerId == request.auth.uid);
      allow write:  if canManagePeopleOps();
    }

    match /peopleOffers/{docId} {
      allow read:   if canManagePeopleOps() || canReadAll();
      allow write:  if canManagePeopleOps();
    }

    match /peopleOnboarding/{docId} {
      allow read:   if canManagePeopleOps() || canReadAll() || isOwnPeopleRecord();
      allow write:  if canManagePeopleOps();
    }

    match /peopleOneOnOneReviews/{docId} {
      allow read: if isSignedIn() && (
        canManagePeopleOps() || canReadAll() ||
        resource.data.managerId == request.auth.uid
      );
      allow create: if canManagePeopleOps() || isManager();
      allow update: if canManagePeopleOps() || resource.data.managerId == request.auth.uid;
      allow delete: if isPlatformAdmin();
    }

    match /peopleLeaveRequests/{docId} {
      allow read: if isSignedIn() && (
        canManagePeopleOps() || canReadAll() ||
        resource.data.createdBy == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if canManagePeopleOps() || resource.data.createdBy == request.auth.uid;
      allow delete: if isPlatformAdmin();
    }

    match /peoplePolicies/{docId} {
      allow read:  if isSignedIn();
      allow write: if canManagePeopleOps();
    }

    match /peoplePolicyAcknowledgements/{docId} {
      allow read: if isSignedIn() && (
        canManagePeopleOps() || resource.data.createdBy == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if false; // Acknowledgements are immutable.
    }

    match /peopleCultureSignals/{docId} {
      allow read: if isSignedIn() && (
        canManagePeopleOps() || canReadAll() ||
        (resource.data.get('visibleToPerson', false) == true && resource.data.createdBy == request.auth.uid)
      );
      allow write: if canManagePeopleOps();
    }

    match /peopleAuditLogs/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn() && (resource.data.uid == request.auth.uid || isPlatformAdmin() || canManagePeopleOps());
      allow update, delete: if false; // Logs are immutable.
    }

    // ── Assignment Comments ────────────────────────────────────────────────
    match /assignmentComments/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || canManageUsers()
      );
      allow delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || isPlatformAdmin()
      );
    }
  }
}
